FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_RUN_PORT=5001
SECRET_KEY=replace-with-a-long-random-secret
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30

# Option 1: provide a complete SQLAlchemy database URL.
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/rungta_employee
# DATABASE_URL=postgresql://postgres:password@host:5432/database
# For Supabase runtime connections, prefer the pooled URL on port 6543.
# DATABASE_URL=postgresql://postgres.project-ref:password@aws-region.pooler.supabase.com:6543/postgres

# Option 2: provide separate PostgreSQL values.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rungta_employee
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
