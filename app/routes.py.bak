        """Update an employee."""
        employee = db.session.get(Employee, employee_id)
        if not employee:
            employee_ns.abort(404, "Employee not found")
        apply_employee_payload(employee, request.get_json() or {})
        commit_or_abort(employee_ns)
        return employee.to_dict()

    @employee_ns.response(204, "Deleted")
    def delete(self, employee_id):
        """Delete an employee."""
        employee = db.session.get(Employee, employee_id)
        if not employee:
            employee_ns.abort(404, "Employee not found")
        db.session.delete(employee)
        commit_or_abort(employee_ns)
        return "", 204
